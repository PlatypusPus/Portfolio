---
interface Props {
  title?: string;
}
const { title = "kazuh.dev" } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const NAV = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/projects", label: "projects" },
  { href: "/contact", label: "contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="boot" class="boot" aria-hidden="true">
      <pre id="boot-log" class="boot-log"></pre>
      <span class="boot-skip">press any key / click to skip</span>
    </div>

    <nav class="navbar">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="prompt">shovin@portfolio:~$</span>
      <div class="nav-links">
        {NAV.map((item) => (
          <a href={item.href} class:list={["nav-link", { active: path === item.href }]}>
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <main class="terminal-body">
      <slot />
    </main>

    <script>
      const boot = document.getElementById("boot");
      const log = document.getElementById("boot-log");

      // OK:  -> green [  OK  ] prefix · ""  -> blank line · plain -> header/login text
      const LINES = [
        "Arch Linux 6.7.0-arch1 (tty1)",
        "",
        "[    0.000000] Booting shov.in kernel ...",
        "OK:Started Load Kernel Modules.",
        "OK:Mounted /home/shovin.",
        "OK:Reached target Local File Systems.",
        "OK:Started Journal Service.",
        "OK:Started D-Bus System Message Bus.",
        "OK:Started Network Manager.",
        "OK:Reached target Network.",
        "OK:Started OpenSSH Daemon.",
        "OK:Started portfolio.service.",
        "OK:Started Display Manager.",
        "OK:Started Minecraft.",
        "OK:Reached target Graphical Interface.",
        "",
        "Arch Linux 6.7.0-arch1 (tty1)",
        "",
        "shovin login: shovin",
        "Last login: " + new Date().toUTCString(),
        "Launching portfolio ...",
      ];

      function markUp(line) {
        if (line === "") return "";
        if (line.startsWith("OK:"))
          return '<span class="ok">[  OK  ]</span> ' + line.slice(3);
        return '<span class="head">' + line + "</span>";
      }

      function done() {
        window.__booted = true;
        window.dispatchEvent(new Event("boot-complete"));
      }

      function skip() {
        boot.classList.add("done");
        setTimeout(() => boot.remove(), 550);
        done();
      }

      const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
      const seen = sessionStorage.getItem("booted");

      if (reduced || seen) {
        boot.remove();
        setTimeout(done, 0);
      } else {
        sessionStorage.setItem("booted", "1");
        let i = 0;
        const step = () => {
          if (i >= LINES.length) {
            setTimeout(skip, 450);
            return;
          }
          const line = LINES[i++];
          log.innerHTML += markUp(line) + "\n";
          // Reached-target lines feel like they "wait" a beat
          const delay = line.startsWith("OK:Reached") ? 160 : line === "" ? 90 : 50;
          timer = setTimeout(step, delay);
        };
        let timer = setTimeout(step, 200);
        const onSkip = () => {
          clearTimeout(timer);
          skip();
        };
        boot.addEventListener("click", onSkip, { once: true });
        addEventListener("keydown", onSkip, { once: true });
      }
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0d0d0d;
    --green:    #00ff41;
    --amber:    #ffb700;
    --text:     #c8c8c8;
    --text-dim: #666;
    --border:   #222;
    --cursor:   #00ff41;
  }

  html, body { height: 100%; }

  /* ── Arch-style boot overlay ── */
  .boot {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    padding: 36px 44px;
    overflow: hidden;
  }
  .boot.done {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .boot-log {
    font-family: 'JetBrains Mono', 'Cascadia Code', monospace;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text);
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
  }
  .boot-log .ok   { color: var(--green); }
  .boot-log .head { color: #e8e8e8; }
  .boot-skip {
    position: fixed;
    bottom: 28px;
    right: 36px;
    font-size: 0.72rem;
    color: var(--text-dim);
    opacity: 0.6;
  }

  body {
    font-family: 'JetBrains Mono', 'Cascadia Code', monospace;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Navbar ── */
  .navbar {
    position: sticky;
    top: 12px;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 28px;
    margin-top: 24px;
    padding: 18px 28px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    flex-wrap: wrap;
  }

  /* mask the 12px gap above the floating bar so content doesn't bleed through */
  .navbar::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: -14px;
    height: 14px;
    background: var(--bg);
  }

  /* ── Framed panel + corner brackets (shared by navbar, hero, pages) ── */
  .panel {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 56px 60px;
    /* faint terminal grid backdrop */
    background-image:
      linear-gradient(rgba(0,255,65,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,65,0.025) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .panel-label {
    position: absolute;
    top: -0.6em;
    left: 32px;
    padding: 0 10px;
    background: var(--bg);
    color: var(--text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid var(--green);
  }
  .corner.tl { top: -1px; left: -1px;  border-right: none; border-bottom: none; }
  .corner.tr { top: -1px; right: -1px; border-left: none;  border-bottom: none; }
  .corner.bl { bottom: -1px; left: -1px;  border-right: none; border-top: none; }
  .corner.br { bottom: -1px; right: -1px; border-left: none;  border-top: none; }

  .prompt {
    color: var(--green);
    font-size: 1rem;
  }

  .nav-links {
    display: flex;
    gap: 26px;
    margin-left: auto;
  }

  .nav-link {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active { color: var(--green); }

  /* ── Body ── */
  .terminal-body {
    padding: 40px 0;
  }

  /* ── Shared bits ── */
  .cursor {
    display: inline-block;
    width: 9px;
    height: 1em;
    background: var(--cursor);
    vertical-align: text-bottom;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  @media (max-width: 500px) {
    .navbar { gap: 12px; }
    .nav-links { gap: 14px; }
  }
</style>
