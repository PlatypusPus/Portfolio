---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import shovin from "../assets/shovin.png";
import ProjectCard from "../components/ProjectCard.astro";
import { PROJECTS } from "../data/projects";

const BIO = `I'm a 4th year engineering student who likes to play games and build projects for fun. Started off customizing Minecraft plugins, ended up building scalable applications.`;
const DISCORD = "mystic_mc";
const FEATURED = PROJECTS.slice(0, 3);

// ── Edit with your real stack ──
const STACK = [
  { label: "languages", items: ["Python", "C", "JavaScript", "C#", "Java"] },
  { label: "frameworks", items: ["React", "Node", "FastAPI", ".NET"] },
  { label: "tools", items: ["Git", "Docker", "Linux", "Postgres"] },
];

// ── Edit with your real education ──
const EDUCATION = [
  {
    title: "B.E. in Computer Engineering",
    place: "St Joseph Engineering College, Mangalore",
    period: "2023 — 2027",
    detail: "Bachelors Of Engineering in Computer Science and Data Science",
  },
  {
    title: "Pre University",
    place: "St Aloysius Pre University College, Mangalore",
    period: "2020 — 2023",
    detail: "PCMC",
  },
];

// ── Talks & workshops you've given (newest first) ──
const TALKS = [
  {
    title: "Taking Control of your version control using Gitea",
    place: "MangaloreFOSS, Niveus Solutions, Udupi",
    period: "Feb 2026",
    detail: "Delivered a technical session on self-hosting Gitea, covering Docker-based deployment, customization, repository mirroring, and the advantages of managing independent Git infrastructure.",
  },
  {
    title: "Linux 101",
    place: "SJEC",
    period: "Dec 2025",
    detail: "Co-facilitated a hands-on Linux workshop, introducing students to the Linux ecosystem, command-line fundamentals, file systems, permissions, and essential terminal operations.",
  },
  {
    title: "Blender 101",
    place: "SJEC",
    period: "May 2025",
    detail: "Facilitated a beginner-friendly Blender workshop, guiding first-year students through 3D modeling, modifiers, and basic animation by creating and animating a ninja blade.",
  },
  {
    title: "CS50x Puzzle Day SJEC",
    place: "SJEC",
    period: "Apr 2025",
    detail: "Designed and conducted an interactive Alternate Reality Game (ARG), introducing participants to cryptography concepts and guiding them through a multi-stage puzzle experience inspired by Harvard CS50x Puzzle Day.",
  },
];

// ── Awards, wins, recognitions ──
const ACHIEVEMENTS = [
  {
    title: "Lead Organizer for HackToFuture 4.0",
    place: "SJEC",
    period: "2026",
    detail:
      "Led the planning and execution of a national-level hackathon, coordinating logistics, volunteers, and event operations while attracting over 3,000 registrations from participants across India.",
  },
  {
    title: "ArduPilot Mission Planner Software Contributor",
    place: "SJEC × Kansas State University (USA)",
    period: "Oct 2024 — Apr 2025",
    detail: "Contributed to enhancing the ArduPilot Mission Planner software through an international collaboration between SJEC and Kansas State University. Implemented unit conversion improvements, telemetry enhancements, UI refinements, and gauge cluster updates, resulting in a more consistent and user-friendly mission planning experience.",
  },
  {
    title: "Winner of GDSC Tech Winter Break",
    place: "SJEC",
    period: "Dec 2024",
    detail: "",
  },
];

// ── Edit with roles you've held ──
const POSITIONS = [
  {
    title: "Vice President",
    place: "The Sceptix Club",
    period: "2025 — Present",
    detail: "",
  },
  {
    title: "Member",
    place: "The Sceptix Club",
    period: "2023 — 2024",
    detail: "",
  },
];
---

<Layout title="shov.in">
  <section class="hero">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~./shovinJesonDsouza</span>

      <div class="profile">
        <div class="profile-text">
          <h1 class="name">Shovin Jeson Dsouza</h1>
          <p class="role">4th Year Engineering Student · Building stuff for fun</p>

          <p class="bio"><span id="bio"></span><span class="cursor" id="cursor"></span></p>
        </div>

        <figure class="avatar">
          <Image src={shovin} alt="Shovin Jeson Dsouza" width={440} densities={[1, 2]} loading="eager" fetchpriority="high" />
          <figcaption>shovin.png</figcaption>
        </figure>
      </div>

      <div class="actions">
        <a class="resume" href="/ShovinJesonDsouza.pdf" target="_blank" rel="noopener">
          <span class="resume-cmd">$ cat</span> resume.pdf
          <span class="resume-arrow">↗</span>
        </a>

        <div class="socials">
          <a href="https://github.com/PlatypusPus" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.92 1.24 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/>
            </svg>
            <span class="tip">PlatypusPus</span>
          </a>
          <a href="https://www.linkedin.com/in/shovindsouza/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/>
            </svg>
            <span class="tip">shovindsouza</span>
          </a>
          <button type="button" class="copy-discord" data-user={DISCORD} aria-label={`Copy Discord username: ${DISCORD}`}>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M20.32 4.37A19.8 19.8 0 0 0 15.45 3l-.24.5c1.7.4 2.48.97 3.3 1.67a13.3 13.3 0 0 0-4.95-1.58 13.7 13.7 0 0 0-3.32 0A13.3 13.3 0 0 0 5.49 5.2c.85-.73 1.66-1.3 3.3-1.7L8.55 3c-1.8.3-3.44.85-4.87 1.37C.61 9.1-.25 13.7.18 18.25a19.9 19.9 0 0 0 6.06 3.06l.49-.66c-.83-.31-1.62-.7-2.36-1.16.2-.14.39-.29.57-.44a14.2 14.2 0 0 0 12.12 0c.18.16.37.3.57.44-.74.46-1.53.85-2.36 1.16l.49.66a19.8 19.8 0 0 0 6.06-3.06c.5-5.27-.85-9.83-3.61-13.88zM8.02 15.45c-1.18 0-2.16-1.1-2.16-2.44 0-1.34.95-2.44 2.16-2.44 1.2 0 2.18 1.1 2.16 2.44 0 1.34-.96 2.44-2.16 2.44zm7.96 0c-1.18 0-2.16-1.1-2.16-2.44 0-1.34.96-2.44 2.16-2.44 1.21 0 2.18 1.1 2.16 2.44 0 1.34-.95 2.44-2.16 2.44z"/>
            </svg>
            <span class="tip">{DISCORD}</span>
          </button>
        </div>
      </div>

      <div class="status" id="status" hidden>
        <span class="dot"></span>
        Available · Summer 2026
      </div>
    </div>
  </section>

  <section class="stack">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~/stack</span>

      <p class="cmd">$ cat stack.txt</p>

      <div class="stack-rows">
        {STACK.map((row) => (
          <div class="stack-row">
            <span class="stack-label">{row.label}/</span>
            <div class="stack-items">
              {row.items.map((it) => <span>{it}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="featured">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~/projects</span>

      <div class="featured-head">
        <p class="cmd">$ ls ~/projects --favorite</p>
        <a class="view-all" href="/projects">view all <span class="arrow">↗</span></a>
      </div>

      <div class="grid">
        {FEATURED.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~/experience</span>

      <p class="cmd">$ cat positions.log</p>

      <div class="timeline">
        {POSITIONS.map((item) => (
          <div class="tl-item">
            <span class="tl-dot"></span>
            <div class="tl-body">
              <div class="tl-head">
                <h3 class="tl-title">{item.title}</h3>
                <span class="tl-period">{item.period}</span>
              </div>
              <p class="tl-place">{item.place}</p>
              {item.detail && <p class="tl-detail">{item.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~/education</span>

      <p class="cmd">$ cat education.log</p>

      <div class="timeline">
        {EDUCATION.map((item) => (
          <div class="tl-item">
            <span class="tl-dot"></span>
            <div class="tl-body">
              <div class="tl-head">
                <h3 class="tl-title">{item.title}</h3>
                <span class="tl-period">{item.period}</span>
              </div>
              <p class="tl-place">{item.place}</p>
              {item.detail && <p class="tl-detail">{item.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~/talks</span>

      <p class="cmd">$ cat talks.log</p>

      <div class="timeline">
        {TALKS.map((item) => (
          <div class="tl-item">
            <span class="tl-dot"></span>
            <div class="tl-body">
              <div class="tl-head">
                <h3 class="tl-title">{item.title}</h3>
                <span class="tl-period">{item.period}</span>
              </div>
              <p class="tl-place">{item.place}</p>
              {item.detail && <p class="tl-detail">{item.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~/achievements</span>

      <p class="cmd">$ cat achievements.log</p>

      <div class="timeline">
        {ACHIEVEMENTS.map((item) => (
          <div class="tl-item">
            <span class="tl-dot"></span>
            <div class="tl-body">
              <div class="tl-head">
                <h3 class="tl-title">{item.title}</h3>
                <span class="tl-period">{item.period}</span>
              </div>
              <p class="tl-place">{item.place}</p>
              {item.detail && <p class="tl-detail">{item.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ BIO }}>
  const CHAR_DELAY = 14;
  const bio = document.getElementById("bio");
  const cursor = document.getElementById("cursor");
  const status = document.getElementById("status");

  function start() {
    let i = 0;
    const timer = setInterval(() => {
      bio.textContent = BIO.slice(0, ++i);
      if (i >= BIO.length) {
        clearInterval(timer);
        cursor.classList.add("blink");
        status.hidden = false;
      }
    }, CHAR_DELAY);
  }

  // wait for the Arch boot overlay to finish before typing
  if (window.__booted) start();
  else addEventListener("boot-complete", start, { once: true });

  const dc = document.querySelector(".copy-discord");
  const tip = dc.querySelector(".tip");
  dc.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(dc.dataset.user);
      tip.textContent = "copied!";
    } catch {
      tip.textContent = dc.dataset.user;
    }
    dc.classList.add("show");
    setTimeout(() => {
      dc.classList.remove("show");
      setTimeout(() => (tip.textContent = dc.dataset.user), 200);
    }, 1100);
  });
</script>

<style>
  .hero { padding: 32px 0; }

  /* ── Tech stack (home) ── */
  .stack { padding: 0 0 32px; }
  .stack .cmd {
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 28px;
  }
  .stack-rows {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .stack-row {
    display: flex;
    align-items: baseline;
    gap: 18px;
  }
  .stack-label {
    flex-shrink: 0;
    width: 110px;
    font-size: 0.9rem;
    color: var(--green);
  }
  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .stack-items span {
    font-size: 0.85rem;
    color: var(--text);
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 5px;
    transition: border-color 0.15s, color 0.15s;
  }
  .stack-items span:hover {
    border-color: var(--green);
    color: var(--green);
  }

  @media (max-width: 540px) {
    .stack-row { flex-direction: column; gap: 8px; }
    .stack-label { width: auto; }
  }

  /* ── Timeline (experience / education) ── */
  .timeline-section { padding: 0 0 32px; }
  .timeline-section .cmd {
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 28px;
  }
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-left: 8px;
    border-left: 1px solid var(--border);
  }
  .tl-item {
    position: relative;
    padding-left: 28px;
  }
  .tl-dot {
    position: absolute;
    left: -5px;
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--green);
  }
  .tl-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .tl-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
  }
  .tl-period {
    font-size: 0.8rem;
    color: var(--text-dim);
    flex-shrink: 0;
  }
  .tl-place {
    font-size: 0.9rem;
    color: var(--green);
    margin-top: 4px;
  }
  .tl-detail {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-dim);
    margin-top: 8px;
    max-width: 680px;
  }

  /* ── Featured projects (home) ── */
  .featured { padding: 0 0 32px; }

  .featured-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
  }
  .featured .cmd {
    font-size: 0.95rem;
    color: var(--text-dim);
  }
  .view-all {
    font-size: 0.9rem;
    color: var(--green);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .view-all:hover { border-bottom-color: var(--green); }
  .view-all .arrow { font-size: 0.85rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
  }

  .profile {
    display: flex;
    align-items: flex-start;
    gap: 48px;
  }
  .profile-text { flex: 1; min-width: 0; }

  /* framed avatar — terminal aesthetic */
  .avatar {
    flex-shrink: 0;
    margin: 0;
    position: relative;
  }
  .avatar img {
    display: block;
    width: 220px;
    height: 220px;
    object-fit: cover;
    border: 1px solid var(--border);
    border-radius: 8px;
    filter: grayscale(0.2) contrast(1.05);
  }
  .avatar figcaption {
    margin-top: 8px;
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .cmd-accent {
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 32px;
    letter-spacing: 0.02em;
  }

  .name {
    font-size: 3rem;
    font-weight: 700;
    color: var(--green);
    line-height: 1.1;
    letter-spacing: -1px;
    text-shadow: 0 0 24px rgba(0,255,65,0.25);
  }

  .role {
    font-size: 1.1rem;
    color: var(--text-dim);
    margin-top: 14px;
  }

  .bio {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
    margin-top: 36px;
    max-width: 680px;
    min-height: 4.5em;
  }

  .cursor {
    display: inline-block;
    width: 10px;
    height: 1em;
    background: var(--green);
    transform: translateY(2px);
    margin-left: 3px;
  }
  .cursor.blink { animation: blink 1.1s step-end infinite; }

  .actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 36px;
  }

  .resume {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .resume:hover {
    border-color: var(--green);
    color: var(--green);
    background: rgba(0, 255, 65, 0.05);
  }
  .resume-cmd { color: var(--green); }
  .resume-arrow { font-size: 0.9rem; opacity: 0.7; }

  .socials {
    display: flex;
    justify-content: center;
    gap: 10px;
    width: 220px; /* match avatar width so icons center under the image */
  }
  .socials a,
  .socials button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-radius: 6px;
    background: none;
    font: inherit;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .socials a:hover,
  .socials button:hover {
    color: var(--green);
    border-color: var(--green);
    background: rgba(0, 255, 65, 0.05);
  }

  /* username preview tooltip (all socials) */
  .socials .tip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 4px 10px;
    font-size: 0.8rem;
    white-space: nowrap;
    color: var(--green);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .socials a:hover .tip,
  .socials button:hover .tip,
  .copy-discord.show .tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .copy-discord.show .tip { border-color: var(--green); }

  .status {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-top: 40px;
    font-size: 1rem;
    color: var(--text-dim);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse-dot 2.4s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,255,65,0.4); }
    50%      { opacity: 0.5; box-shadow: 0 0 0 6px rgba(0,255,65,0); }
  }

  @media (max-width: 760px) {
    .profile { flex-direction: column-reverse; gap: 28px; }
    .avatar { align-self: flex-start; }
    .avatar img { width: 160px; height: 160px; }
  }

  @media (max-width: 600px) {
    .panel { padding: 40px 28px; }
    .name { font-size: 2rem; }
    .bio { font-size: 1rem; }
  }
</style>
