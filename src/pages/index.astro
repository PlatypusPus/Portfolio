---
import Layout from "../layouts/Layout.astro";

const BIO = `I'm a 4th year engineering student who likes to play games and build projects for fun. Started off customizing Minecraft plugins, ended up building scalable applications.`;
---

<Layout title="shov.in">
  <section class="hero">
    <div class="panel">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="panel-label">~./shovinJesonDsouza</span>

      <div class="profile">
        <div class="profile-text">
          <h1 class="name">Shovin Jeson Dsouza</h1>
          <p class="role">4th Year Engineering Student · Building stuff for fun</p>

          <p class="bio"><span id="bio"></span><span class="cursor" id="cursor"></span></p>

          <div class="skills">
            <span>Python</span>
            <span>C</span>
            <span>JavaScript</span>
            <span>C#</span>
          </div>

          <div class="status" id="status" hidden>
            <span class="dot"></span>
            Available · Summer 2026
          </div>
        </div>

        <figure class="avatar">
          <img src="/shovin.png" alt="Shovin Jeson Dsouza" width="220" height="220" />
          <figcaption>shovin.png</figcaption>
        </figure>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ BIO }}>
  const CHAR_DELAY = 14;
  const bio = document.getElementById("bio");
  const cursor = document.getElementById("cursor");
  const status = document.getElementById("status");

  function start() {
    let i = 0;
    const timer = setInterval(() => {
      bio.textContent = BIO.slice(0, ++i);
      if (i >= BIO.length) {
        clearInterval(timer);
        cursor.classList.add("blink");
        status.hidden = false;
      }
    }, CHAR_DELAY);
  }

  // wait for the Arch boot overlay to finish before typing
  if (window.__booted) start();
  else addEventListener("boot-complete", start, { once: true });
</script>

<style>
  .hero { padding: 32px 0; }

  .profile {
    display: flex;
    align-items: flex-start;
    gap: 48px;
  }
  .profile-text { flex: 1; min-width: 0; }

  /* framed avatar — terminal aesthetic */
  .avatar {
    flex-shrink: 0;
    margin: 0;
    position: relative;
  }
  .avatar img {
    display: block;
    width: 220px;
    height: 220px;
    object-fit: cover;
    border: 1px solid var(--border);
    border-radius: 8px;
    filter: grayscale(0.2) contrast(1.05);
  }
  .avatar figcaption {
    margin-top: 8px;
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .cmd-accent {
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 32px;
    letter-spacing: 0.02em;
  }

  .name {
    font-size: 3rem;
    font-weight: 700;
    color: var(--green);
    line-height: 1.1;
    letter-spacing: -1px;
    text-shadow: 0 0 24px rgba(0,255,65,0.25);
  }

  .role {
    font-size: 1.1rem;
    color: var(--text-dim);
    margin-top: 14px;
  }

  .bio {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
    margin-top: 36px;
    max-width: 680px;
    min-height: 4.5em;
  }

  .cursor {
    display: inline-block;
    width: 10px;
    height: 1em;
    background: var(--green);
    transform: translateY(2px);
    margin-left: 3px;
  }
  .cursor.blink { animation: blink 1.1s step-end infinite; }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 36px;
  }
  .skills span {
    font-size: 0.95rem;
    color: var(--text);
    padding: 7px 16px;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.15s, color 0.15s;
  }
  .skills span:hover {
    border-color: var(--green);
    color: var(--green);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-top: 40px;
    font-size: 1rem;
    color: var(--text-dim);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse-dot 2.4s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,255,65,0.4); }
    50%      { opacity: 0.5; box-shadow: 0 0 0 6px rgba(0,255,65,0); }
  }

  @media (max-width: 760px) {
    .profile { flex-direction: column-reverse; gap: 28px; }
    .avatar { align-self: flex-start; }
    .avatar img { width: 160px; height: 160px; }
  }

  @media (max-width: 600px) {
    .panel { padding: 40px 28px; }
    .name { font-size: 2rem; }
    .bio { font-size: 1rem; }
  }
</style>
