---
interface Props {
  title?: string;
}
const { title = "kazuh.dev" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="navbar">
      <span class="prompt">shovin@portfolio:~$</span>
      <div class="nav-links">
        <a href="/" class="nav-link active">home</a>
        <a href="/about" class="nav-link">about</a>
        <a href="/projects" class="nav-link">projects</a>
        <a href="/contact" class="nav-link">contact</a>
      </div>
    </nav>

    <main class="terminal-body">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0d0d0d;
    --green:    #00ff41;
    --amber:    #ffb700;
    --text:     #c8c8c8;
    --text-dim: #666;
    --border:   #222;
    --cursor:   #00ff41;
  }

  html, body { height: 100%; }

  body {
    font-family: 'JetBrains Mono', 'Cascadia Code', monospace;
    font-size: 16px;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Navbar ── */
  .navbar {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .prompt {
    color: var(--green);
    font-size: 1rem;
  }

  .nav-links {
    display: flex;
    gap: 26px;
    margin-left: auto;
  }

  .nav-link {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active { color: var(--green); }

  /* ── Body ── */
  .terminal-body {
    padding: 40px 0;
  }

  /* ── Shared bits ── */
  .cursor {
    display: inline-block;
    width: 9px;
    height: 1em;
    background: var(--cursor);
    vertical-align: text-bottom;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  @media (max-width: 500px) {
    .navbar { gap: 12px; }
    .nav-links { gap: 14px; }
  }
</style>
